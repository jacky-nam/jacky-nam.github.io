# Normalize all text files to LF in the repo and the working tree.
# Keeps line endings consistent across machines and silences the
# "LF will be replaced by CRLF" warnings on Windows.
* text=auto eol=lf

# Binary assets — never touch line endings.
*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
